# Google Maps JavaScript API key (Maps JavaScript API, Places API, Geocoding API must be enabled).
# Restrict it by HTTP referrer in the Google Cloud Console since it is exposed to the browser.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=

# Secret used to sign session tokens. Generate one with: openssl rand -hex 32
AUTH_SECRET=

# Optional: Resend API key for sending password reset emails (https://resend.com).
# When unset, reset links are logged to the server console instead (dev mode).
RESEND_API_KEY=

# Optional: the From address for outgoing email. Defaults to Resend's onboarding sender.
EMAIL_FROM="ParkPoint <noreply@yourdomain.com>"
